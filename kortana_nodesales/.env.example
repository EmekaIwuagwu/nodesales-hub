# ─── SMART CONTRACTS ──────────────────────────────────────────────
PRIVATE_KEY=0x...

# ─── BACKEND ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://kortana:password@cluster.mongodb.net/kortana-prod
JWT_SECRET=your-256-bit-random-secret
JWT_EXPIRES_IN=24h
PORT=4000
ALLOWED_ORIGIN=https://kortana.xyz

# Chain
KORTANA_RPC_URL=https://zeus-rpc.mainnet.kortana.xyz
KORTANA_CHAIN_ID=9002

# Reward distributor wallet (use AWS KMS in production)
DISTRIBUTOR_PRIVATE_KEY=0x...
DISTRIBUTOR_ADDRESS=0x...

# Contract addresses (filled by deploy.js)
NODE_SALE_ADDRESS=0x...
REWARD_VAULT_ADDRESS=0x...
GENESIS_LICENSE_ADDRESS=0x...
EARLY_LICENSE_ADDRESS=0x...
FULL_LICENSE_ADDRESS=0x...
PREMIUM_LICENSE_ADDRESS=0x...
USDT_ADDRESS=0x...
DNR_ADDRESS=0x...

# Treasury
TREASURY=0x...

# Cron schedule (default: 12:00 UTC daily)
REWARD_CRON_SCHEDULE=0 12 * * *

# Alerts
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ─── FRONTEND (Vite env vars) ──────────────────────────────────────
VITE_API_URL=https://api.kortana.xyz
VITE_NODE_SALE_ADDRESS=0x...
VITE_REWARD_VAULT_ADDRESS=0x...
VITE_USDT_ADDRESS=0x...
VITE_CHAIN_ID=9002
VITE_RPC_URL=https://zeus-rpc.mainnet.kortana.xyz
VITE_EXPLORER_URL=https://explorer.mainnet.kortana.xyz
VITE_WALLETCONNECT_PROJECT_ID=...
