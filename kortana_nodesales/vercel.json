{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "cd frontend && npm install --include=dev && npx vite build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "crons": [
    {
      "path": "/api/cron/distribute?secret=kortana-cron-2026",
      "schedule": "0 * * * *"
    }
  ]
}
