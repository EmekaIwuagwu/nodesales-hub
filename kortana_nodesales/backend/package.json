{
  "name": "kortana-nodesale-backend",
  "version": "1.0.0",
  "description": "Kortana Node Sale — Express/MongoDB Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev":   "nodemon src/index.js",
    "test":  "jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/test/**/*.test.js"],
    "testTimeout":     30000
  },
  "dependencies": {
    "express":            "^4.19.2",
    "mongoose":           "^8.4.0",
    "ethers":             "^6.12.1",
    "siwe":               "^2.3.2",
    "jsonwebtoken":       "^9.0.2",
    "bcryptjs":           "^2.4.3",
    "dotenv":             "^16.4.5",
    "cors":               "^2.8.5",
    "helmet":             "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "node-cron":          "^3.0.3",
    "winston":            "^3.13.0",
    "zod":                "^3.23.8",
    "axios":              "^1.7.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "nodemon":              "^3.1.3",
    "jest":                 "^29.7.0",
    "supertest":            "^7.0.0",
    "mongodb-memory-server":"^10.0.0"
  }
}
