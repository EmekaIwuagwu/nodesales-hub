    "lucide-react": "^0.378.0",
    "next": "14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "viem": "^2.13.0",
    "wagmi": "^2.9.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
