<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Gradient Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryGradient}" />
        <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
        <Setter Property="FontFamily" Value="{StaticResource InterSemiBold}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Ghost / Outline Button Style -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderColor" Value="{StaticResource PureWhite}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
        <Setter Property="FontFamily" Value="{StaticResource InterSemiBold}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                            <Setter Property="BackgroundColor" Value="#1AFFFFFF" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Pin Pad Button Style -->
    <Style x:Key="PinButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#0DFFFFFF" /> <!-- rgba(255, 255, 255, 0.05) -->
        <Setter Property="BorderColor" Value="{StaticResource RoyalKortanaBlue}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontFamily" Value="{StaticResource InterSemiBold}" />
        <Setter Property="HeightRequest" Value="72" />
        <Setter Property="WidthRequest" Value="72" />
        <Setter Property="CornerRadius" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1.1" />
                            <Setter Property="BackgroundColor" Value="{StaticResource ElectricCobalt}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Floating Action Button (FAB) Style -->
    <Style x:Key="FabButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ElectricCobalt}" />
        <Setter Property="TextColor" Value="{StaticResource PureWhite}" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource ElectricCobalt}" Offset="0,4" Radius="8" Opacity="0.5" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
