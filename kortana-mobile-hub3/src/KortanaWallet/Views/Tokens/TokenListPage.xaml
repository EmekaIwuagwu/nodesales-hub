<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KortanaWallet.ViewModels"
             xmlns:models="clr-namespace:KortanaWallet.Models"
             x:Class="KortanaWallet.Views.Tokens.TokenListPage"
             x:DataType="vm:TokenListViewModel"
             Title="Assets">

    <Grid RowDefinitions="Auto, *">
        <!-- Search -->
        <SearchBar Grid.Row="0" Placeholder="Search tokens..." Style="{StaticResource PrimarySearchBarStyle}" Margin="20,10" />

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadTokensCommand}">
            <CollectionView ItemsSource="{Binding Tokens}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Token">
                        <Border Style="{StaticResource GlassCardStyle}" Margin="20,0,20,12" Padding="16">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Ellipse Grid.Column="0" WidthRequest="40" HeightRequest="40" Fill="{StaticResource CardGradient}" Margin="0,0,12,0" />
                                
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyLarge}" />
                                    <Label Text="{Binding Symbol}" Style="{StaticResource Caption}" />
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center">
                                    <Label Text="{Binding Balance, StringFormat='{0:N4}'}" Style="{StaticResource BodyLarge}" HorizontalOptions="End" />
                                    <Label Text="{Binding TotalValueUsd, StringFormat='{0:C2}'}" Style="{StaticResource Caption}" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Floating Add Button -->
        <Button Grid.Row="1" Text="+" 
                Style="{StaticResource PrimaryButtonStyle}" 
                WidthRequest="56" HeightRequest="56" 
                CornerRadius="28" Padding="0" 
                VerticalOptions="End" HorizontalOptions="End" 
                Margin="30" 
                Command="{Binding ImportTokenCommand}" />

    </Grid>
</ContentPage>
