<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KortanaWallet.ViewModels"
             x:Class="KortanaWallet.Views.Swap.SwapPage"
             x:DataType="vm:SwapViewModel"
             Title="Swap Assets">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="24">
            
            <Label Text="Quick Swap" Style="{StaticResource H2Section}" HorizontalOptions="Center" />
            <Label Text="The most efficient route across Kortana Network." Style="{StaticResource BodyMedium}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />

            <Grid RowDefinitions="Auto, Auto, Auto">
                
                <!-- From -->
                <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="20">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                        <Label Grid.Row="0" Grid.Column="0" Text="From" Style="{StaticResource Caption}" />
                        <Entry Grid.Row="1" Grid.Column="0" Placeholder="0.0" Keyboard="Numeric" FontSize="32" Text="{Binding FromAmount}" BackgroundColor="Transparent" TextColor="{StaticResource PureWhite}" />
                        
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" VerticalOptions="Center" Spacing="8">
                            <Ellipse WidthRequest="24" HeightRequest="24" Fill="{StaticResource CrystalBlue}" VerticalOptions="Center" />
                            <Label Text="{Binding FromToken.Symbol}" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                            <Label Text="▼" Style="{StaticResource Caption}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- Flip Icon -->
                <Button Grid.Row="1" Text="⇵" 
                        WidthRequest="44" HeightRequest="44" 
                        CornerRadius="22" 
                        BackgroundColor="{StaticResource MidnightNavy}" 
                        TextColor="{StaticResource ElectricCobalt}" 
                        BorderColor="{StaticResource ElectricCobalt}" 
                        BorderWidth="1" 
                        ZIndex="1" 
                        TranslationY="-22" 
                        VerticalOptions="Center" HorizontalOptions="Center" 
                        Command="{Binding FlipTokensCommand}" />

                <!-- To -->
                <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="20" TranslationY="-44">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                        <Label Grid.Row="0" Grid.Column="0" Text="To (Estimated)" Style="{StaticResource Caption}" />
                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding ToAmount}" FontSize="32" VerticalOptions="Center" TextColor="{StaticResource PureWhite}" />
                        
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" VerticalOptions="Center" Spacing="8">
                            <Ellipse WidthRequest="24" HeightRequest="24" Fill="{StaticResource SuccessGreen}" VerticalOptions="Center" />
                            <Label Text="{Binding ToToken.Symbol}" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                            <Label Text="▼" Style="{StaticResource Caption}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <!-- Metadata -->
            <VerticalStackLayout Spacing="12" TranslationY="-44">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Exchange Rate" Style="{StaticResource Caption}" />
                    <Label Grid.Column="1" Text="{Binding ExchangeRate, StringFormat='1 KOR = {0:F4} ETH'}" Style="{StaticResource MonoTiny}" HorizontalOptions="End" />
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Slippage Tolerance" Style="{StaticResource Caption}" />
                    <Label Grid.Column="1" Text="0.5%" Style="{StaticResource MonoTiny}" HorizontalOptions="End" />
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Network Fee" Style="{StaticResource Caption}" />
                    <Label Grid.Column="1" Text="≈ $0.08" Style="{StaticResource MonoTiny}" HorizontalOptions="End" />
                </Grid>
            </VerticalStackLayout>

            <Button Text="Swap Now" Style="{StaticResource PrimaryButtonStyle}" TranslationY="-44" Command="{Binding SwapCommand}" Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
