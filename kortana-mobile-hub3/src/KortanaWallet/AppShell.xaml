<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="KortanaWallet.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:KortanaWallet"
    xmlns:views="clr-namespace:KortanaWallet.Views"
    xmlns:splash="clr-namespace:KortanaWallet.Views.Splash"
    xmlns:onboarding="clr-namespace:KortanaWallet.Views.Onboarding"
    xmlns:auth="clr-namespace:KortanaWallet.Views.Auth"
    xmlns:dashboard="clr-namespace:KortanaWallet.Views.Dashboard"
    xmlns:history="clr-namespace:KortanaWallet.Views.History"
    xmlns:swap="clr-namespace:KortanaWallet.Views.Swap"
    xmlns:settings="clr-namespace:KortanaWallet.Views.Settings"
    Shell.FlyoutBehavior="Disabled">

    <!-- Splash Screen (Initial) -->
    <ShellContent
        Title="Splash"
        ContentTemplate="{DataTemplate splash:SplashPage}"
        Route="Splash" />

    <!-- Auth Flow -->
    <ShellContent
        Title="Onboarding"
        ContentTemplate="{DataTemplate onboarding:OnboardingPage}"
        Route="Onboarding" />
    
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate auth:LoginPage}"
        Route="Login" />

    <!-- Main App Tabbed Interface -->
    <TabBar>
        <Tab Title="Home" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate dashboard:DashboardPage}" Route="Dashboard" />
        </Tab>
        <Tab Title="Activity" Icon="activity_icon.png">
            <ShellContent ContentTemplate="{DataTemplate history:TransactionHistoryPage}" Route="History" />
        </Tab>
        <Tab Title="Swap" Icon="swap_icon.png">
            <ShellContent ContentTemplate="{DataTemplate swap:SwapPage}" Route="Swap" />
        </Tab>
        <Tab Title="Settings" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate settings:SettingsPage}" Route="Settings" />
        </Tab>
    </TabBar>

</Shell>
