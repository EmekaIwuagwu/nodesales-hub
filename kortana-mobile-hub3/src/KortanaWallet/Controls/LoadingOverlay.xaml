<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KortanaWallet.Controls.LoadingOverlay"
             x:Name="this"
             IsVisible="{Binding IsBusy, Source={Reference this}}"
             ZIndex="999">

    <Grid BackgroundColor="#CC0A0E27">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <ActivityIndicator 
                IsRunning="{Binding IsBusy, Source={Reference this}}"
                Color="{StaticResource ElectricCobalt}"
                HeightRequest="60"
                WidthRequest="60" />
            
            <Label x:Name="LoadingLabel" 
                   Text="{Binding Message, Source={Reference this}}" 
                   Style="{StaticResource BodyLarge}" 
                   HorizontalOptions="Center" 
                   TextColor="{StaticResource CrystalBlue}" />
        </VerticalStackLayout>
    </Grid>

</ContentView>
