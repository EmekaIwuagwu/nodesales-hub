<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="KortanaWallet.Controls.PinPad"
             x:Name="this">

    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="20">
        <!-- Row 1 -->
        <Button Grid.Row="0" Grid.Column="0" Text="1" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="1" />
        <Button Grid.Row="0" Grid.Column="1" Text="2" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="2" />
        <Button Grid.Row="0" Grid.Column="2" Text="3" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="3" />

        <!-- Row 2 -->
        <Button Grid.Row="1" Grid.Column="0" Text="4" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="4" />
        <Button Grid.Row="1" Grid.Column="1" Text="5" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="5" />
        <Button Grid.Row="1" Grid.Column="2" Text="6" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="6" />

        <!-- Row 3 -->
        <Button Grid.Row="2" Grid.Column="0" Text="7" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="7" />
        <Button Grid.Row="2" Grid.Column="1" Text="8" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="8" />
        <Button Grid.Row="2" Grid.Column="2" Text="9" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="9" />

        <!-- Row 4 -->
        <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource PinButtonStyle}" Command="{Binding BiometricCommand, Source={Reference this}}">
            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialIcons" Glyph="fingerprint" Color="{StaticResource PureWhite}" />
            </Button.ImageSource>
        </Button>
        <Button Grid.Row="3" Grid.Column="1" Text="0" Style="{StaticResource PinButtonStyle}" Command="{Binding ButtonCommand, Source={Reference this}}" CommandParameter="0" />
        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource PinButtonStyle}" Command="{Binding BackspaceCommand, Source={Reference this}}">
            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialIcons" Glyph="backspace" Color="{StaticResource PureWhite}" />
            </Button.ImageSource>
        </Button>
    </Grid>

</ContentView>
